# Copy to .env (gitignored) and fill in your key(s).
# docker-compose passes these into the container; the AI layer + NVD read them.
#
#   cp .env.example .env && $EDITOR .env
#   docker compose up -d          # container picks up the keys
#
# CLI lab run on the host (loads .env into the shell first):
#   set -a; . ./.env; set +a
#   uv run celsius scan <target> --lab --ai --scope scope.yml --lab-attest "..."

DEEPSEEK_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVD_API_KEY=
SHODAN_API_KEY=
CENSYS_PAT=
CENSYS_ORG_ID=
